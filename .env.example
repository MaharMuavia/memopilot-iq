# MemoPilot IQ environment configuration.
# Copy this file to backend/.env (or export these vars) and fill in real values.
# NEVER commit a filled-in .env — it is git-ignored. Leave placeholders empty here.

# Runtime mode: "local" (SQLite + local vectors) or "alibaba" (cloud store).
APP_MODE=local

# --- Qwen Cloud (Alibaba Cloud DashScope, OpenAI-compatible endpoint) ---
QWEN_API_KEY=
QWEN_BASE_URL=
QWEN_CHAT_MODEL=
QWEN_EMBEDDING_MODEL=
# Retry one transient timeout/rate-limit/server failure before honest fallback.
QWEN_REQUEST_TIMEOUT_SECONDS=60
QWEN_MAX_RETRIES=1
# Disable deep thinking for responsive chat; cap concise demo responses.
QWEN_ENABLE_THINKING=false
QWEN_MAX_OUTPUT_TOKENS=700

# --- Alibaba Cloud credentials (only needed for ALIBABA_CLOUD_MODE) ---
ALIBABA_ACCESS_KEY_ID=
ALIBABA_ACCESS_KEY_SECRET=
ALIBABA_REGION=
ALIBABA_OSS_BUCKET=
ALIBABA_OSS_ENDPOINT=
ALIBABA_TABLESTORE_ENDPOINT=
ALIBABA_TABLESTORE_INSTANCE=

# --- Optional: extra backbones for the cross-model benchmark study only ---
# Qwen stays the production model; these are used solely by /api/eval/run to
# evaluate the MemoPilot memory layer across LLMs. Leave empty to run Qwen-only.
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o
GEMINI_API_KEY=
GEMINI_CHAT_MODEL=gemini-2.0-flash

# --- Storage ---
MEMORY_STORE=sqlite
DATABASE_URL=sqlite:///./memopilot.db
# Optional path for persisting the latest synthetic evaluation report across restarts.
EVAL_REPORT_PATH=

# --- Web ---
FRONTEND_ORIGIN=http://localhost:5173

# --- Memory retrieval relevance gate ---
# Non-critical memories must satisfy either threshold before context injection.
RETRIEVAL_MIN_SIMILARITY=0.62
RETRIEVAL_MIN_KEYWORD_OVERLAP=0.20

# --- Production platform (optional) ---
# Comma-separated API keys. When set, every /api/* request must send a
# matching X-API-Key header. Each key is isolated into its own server-side
# memory namespace; do not expose these keys in a browser bundle.
# Leave empty only for local/demo mode.
MEMOPILOT_API_KEYS=
# Public browser deployments can instead issue each browser a signed, HttpOnly
# anonymous tenant cookie. Use a persistent random secret of at least 32 bytes.
# Example generator: openssl rand -hex 32
MEMOPILOT_PUBLIC_DEMO_ISOLATION=false
MEMOPILOT_IDENTITY_SECRET=
# Set true when HTTPS terminates at a reverse proxy in front of the backend.
MEMOPILOT_COOKIE_SECURE=false
# Required for evaluation/maintenance POST endpoints on a public deployment.
MEMOPILOT_ADMIN_KEY=
# Sliding-window rate limit per key/IP (requests per minute).
RATE_LIMIT_PER_MINUTE=120

# Deployment provenance shown by /health and the Settings panel.
APP_BUILD_SHA=development

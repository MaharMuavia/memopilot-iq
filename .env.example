# MemoPilot IQ environment configuration.
# Copy this file to backend/.env (or export these vars) and fill in real values.
# NEVER commit a filled-in .env — it is git-ignored. Leave placeholders empty here.

# Runtime mode: "local" (SQLite + local vectors) or "alibaba" (cloud store).
APP_MODE=local

# --- Qwen Cloud (Alibaba Cloud DashScope, OpenAI-compatible endpoint) ---
QWEN_API_KEY=
QWEN_BASE_URL=
QWEN_CHAT_MODEL=
QWEN_EMBEDDING_MODEL=

# --- Alibaba Cloud credentials (only needed for ALIBABA_CLOUD_MODE) ---
ALIBABA_ACCESS_KEY_ID=
ALIBABA_ACCESS_KEY_SECRET=
ALIBABA_REGION=
ALIBABA_OSS_BUCKET=
ALIBABA_OSS_ENDPOINT=
ALIBABA_TABLESTORE_ENDPOINT=
ALIBABA_TABLESTORE_INSTANCE=

# --- Storage ---
MEMORY_STORE=sqlite
DATABASE_URL=sqlite:///./memopilot.db

# --- Web ---
FRONTEND_ORIGIN=http://localhost:5173

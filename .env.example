# MemoPilot IQ environment configuration.
# Copy this file to backend/.env (or export these vars) and fill in real values.
# NEVER commit a filled-in .env — it is git-ignored. Leave placeholders empty here.

# Runtime mode: "local" (SQLite + local vectors) or "alibaba" (cloud store).
APP_MODE=local

# --- Qwen Cloud (Alibaba Cloud DashScope, OpenAI-compatible endpoint) ---
QWEN_API_KEY=
QWEN_BASE_URL=
QWEN_CHAT_MODEL=
QWEN_EMBEDDING_MODEL=

# --- Alibaba Cloud credentials (only needed for ALIBABA_CLOUD_MODE) ---
ALIBABA_ACCESS_KEY_ID=
ALIBABA_ACCESS_KEY_SECRET=
ALIBABA_REGION=
ALIBABA_OSS_BUCKET=
ALIBABA_OSS_ENDPOINT=
ALIBABA_TABLESTORE_ENDPOINT=
ALIBABA_TABLESTORE_INSTANCE=

# --- Optional: extra backbones for the cross-model benchmark study only ---
# Qwen stays the production model; these are used solely by /api/eval/run to
# show MemoryOS generalizes across LLMs. Leave empty to run Qwen-only.
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o
GEMINI_API_KEY=
GEMINI_CHAT_MODEL=gemini-2.0-flash

# --- Storage ---
MEMORY_STORE=sqlite
DATABASE_URL=sqlite:///./memopilot.db

# --- Web ---
FRONTEND_ORIGIN=http://localhost:5173

# --- Production platform (optional) ---
# Comma-separated API keys. When set, every /api/* request must send a
# matching X-API-Key header. Each key is isolated into its own server-side
# memory namespace; do not expose these keys in a browser bundle.
# Leave empty only for local/demo mode.
MEMOPILOT_API_KEYS=
# Sliding-window rate limit per key/IP (requests per minute).
RATE_LIMIT_PER_MINUTE=120

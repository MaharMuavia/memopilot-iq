# MemoPilot IQ — production env for Alibaba Cloud ECS.
# Copy to deploy/.env.production on the ECS box and fill in real values.
# deploy/.env.production is git-ignored — NEVER commit your real key.

# ---------------------------------------------------------------------------
# MODE A (fast proof): backend runs on Alibaba Cloud ECS + uses Qwen (DashScope).
# /health reports LOCAL_MODE for storage but the backend IS on Alibaba Cloud
# compute and every AI call hits Alibaba Cloud's Qwen API. Leave the ALIBABA_*
# store vars empty for this mode.
# ---------------------------------------------------------------------------
APP_MODE=local
MEMORY_STORE=sqlite

# --- Qwen Cloud (Alibaba Cloud DashScope) — REQUIRED ---
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_CHAT_MODEL=qwen3.7-max
QWEN_EMBEDDING_MODEL=text-embedding-v3

# CORS: set to your frontend URL, or * while testing the API directly.
FRONTEND_ORIGIN=*

# ---------------------------------------------------------------------------
# MODE B (full cloud): also persist memory in Alibaba Tablestore + OSS so
# /health reports ALIBABA_CLOUD_MODE. Fill these in and set the two lines:
#   APP_MODE=alibaba
#   MEMORY_STORE=alibaba
# ---------------------------------------------------------------------------
ALIBABA_ACCESS_KEY_ID=
ALIBABA_ACCESS_KEY_SECRET=
ALIBABA_REGION=
ALIBABA_OSS_BUCKET=
ALIBABA_OSS_ENDPOINT=
ALIBABA_TABLESTORE_ENDPOINT=
ALIBABA_TABLESTORE_INSTANCE=
